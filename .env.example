# Copy to .env for local development or configure these names as Cursor secrets.
# Keep real secret values out of git.

# Supabase Postgres / SQLAlchemy
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# Supabase API / storage
SUPABASE_URL=
SUPABASE_DB_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_IMAGE_BUCKET=pictures
SUPABASE_IMAGE_BASE_FOLDER=product
SUPABASE_KB_SCHEMA=kb
SUPABASE_KB_RPC=match_kb_parts
SUPABASE_KB_TABLE=kb_parts
SUPABASE_KB_IMAGE_BUCKET=kb-parts

# Supabase CLI migrations
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# OpenAI / AI features
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=12
AI_FORMAT_KB_ENABLED=false
AI_FORMAT_KB_MODEL=gpt-4o-mini
KB_MATCH_COUNT=3
KB_AUTO_THRESHOLD=0.90
KB_MIN_GAP=0.06
KB_MAX_IMAGES=3

# Background worker
WORKER_NAME=
WORKER_POLL_SECONDS=3
HEARTBEAT_INTERVAL_SECONDS=10
WORKER_COMMAND_TIMEOUT_SECONDS=1800
WORKER_RESULT_MAX_CHARS=1200

# Optional per-job worker settings; replace <JOB_NAME> with an uppercase job key.
# WORKER_JOB_<JOB_NAME>_ENABLED=true
# WORKER_JOB_<JOB_NAME>_COMMAND=
# WORKER_JOB_<JOB_NAME>_CWD=
# WORKER_JOB_<JOB_NAME>_TIMEOUT_SECONDS=
# WORKER_JOB_<JOB_NAME>_SHELL=true
